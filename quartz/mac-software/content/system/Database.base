views:
  - type: table
    name: Table
    filters:
      and:
        - file.folder != "system"
        - file.folder != "system/templates"
        - '!file.folder.contains("system/trash")'
        - file.name != "index"
    groupBy:
      property: file.folder
      direction: ASC
    order:
      - file.name
      - category
      - install-method
      - tags
      - URL
